    {
      "parameters": {
        "promptType": "define",
        "text": "={{ $json.output }}",
        "options": {
          "systemMessage": "You are a priority classification system. Assign priority levels to action items based on impact and urgency.\n\nINPUT: A JSON array of action items from a meeting transcript\nOUTPUT: Same JSON array with priority field added to each item\n\nRULES:\n- HIGH: Deadline this week, blocks other work, critical to project, mentioned with urgency\n- MEDIUM: Deadline next 1-2 weeks, important but not blocking\n- LOW: Nice to have, deadline 3+ weeks away, no blocking dependencies\n- If no deadline mentioned, use context to infer priority\n- If owner is CEO/executive and involves them, default to HIGH\n- Always return valid JSON array\n\nAdd a \"priority\" field to each item without removing other fields.\n\nReturn ONLY the JSON array with priority added, nothing else.\n\nExample:\nInput: [{\"item\": \"Fix bug\", \"owner\": \"Bob\", \"deadline\": \"Friday\"}]\nOutput: [{\"item\": \"Fix bug\", \"owner\": \"Bob\", \"deadline\": \"Friday\", \"priority\": \"HIGH\"}]"
        }
      },
      "type": "@n8n/n8n-nodes-langchain.agent",
      "typeVersion": 3.1,
      "position": [
        1616,
        176
      ],
      "id": "5f811070-58ff-430f-bdc9-6c86b0255016",
      "name": "AI Agent - Priority Classifier"
    },
    {
      "parameters": {
        "promptType": "define",
        "text": "={{ $('Edit Fields').item.json.meeting_transcript }}",
        "options": {
          "systemMessage": "=You are a risk analyst. Identify risks and blockers from this meeting transcript.\n\nRULES:\n- Identify explicit blockers mentioned\n- Classify severity: HIGH, MEDIUM, LOW\n- Return JSON array\n\nReturn ONLY this JSON:\n[\n  {\n    \"blocker\": \"...\",\n    \"severity\": \"HIGH|MEDIUM|LOW\",\n    \"context\": \"...\"\n  }\n]\n\nIf no blockers found, return empty array []."
        }
      },
      "type": "@n8n/n8n-nodes-langchain.agent",
      "typeVersion": 3.1,
      "position": [
        1968,
        176
      ],
      "id": "697bad9a-944f-455b-8cdd-fe73e4fcfc58",
      "name": "AI Agent - Risk Assesment"
    },
    {
      "parameters": {
        "promptType": "define",
        "text": "={{ $('Edit Fields').item.json.meeting_transcript }}",
        "options": {
          "systemMessage": "=You are a business analyst extracting action items from meeting transcripts.\n\nINPUT: A meeting transcript\nOUTPUT: A JSON array of action items\n\nRULES:\n- Extract only explicit action items\n- Include: what, who is doing it, deadline if mentioned\n- If no owner, assign \"TBD\"\n- If no deadline, put \"No deadline\"\n- Return JSON array format\n\nReturn ONLY this JSON, nothing else:\n[\n  {\n    \"item\": \"...\",\n    \"owner\": \"...\",\n    \"deadline\": \"...\"\n  }\n]\n\nIf no action items found, return empty array []."
        }
      },
      "type": "@n8n/n8n-nodes-langchain.agent",
      "typeVersion": 3.1,
      "position": [
        1264,
        176
      ],
      "id": "7809d10d-37af-4c85-a1e4-b3e35909f463",
      "name": "AI Agent - Action Items",
      "onError": "continueRegularOutput",
      "notes": "={\n  \"status\": \"error\",\n  \"message\": \"Processing failed\",\n  \"error_type\": \"{{ $json.error_type || 'unknown' }}\",\n  \"error_details\": \"{{ $json.error_message || 'No details available' }}\",\n  \"timestamp\": \"{{ new Date().toISOString() }}\",\n  \"recommendation\": \"Check OpenAI API status or contact support\"\n}"
    },
    {
      "parameters": {
        "promptType": "define",
        "text": "={{ $('Edit Fields').item.json.meeting_transcript }}",
        "options": {
          "systemMessage": "=You are a business meeting analyst. Your job is to create executive summaries of meeting transcripts.\n\nINPUT: A meeting transcript\nOUTPUT: A JSON object with a \"summary\" field\n\nRULES:\n- Summary must be 2-3 sentences maximum\n- Focus on key decisions and outcomes\n- Use professional language\n- Ignore chitchat and small talk\n\nReturn ONLY this JSON format, nothing else:\n{\n  \"summary\": \"...\"\n}"
        }
      },
      "type": "@n8n/n8n-nodes-langchain.agent",
      "typeVersion": 3.1,
      "position": [
        928,
        176
      ],
      "id": "e08d01e8-22fa-45cb-84fb-5b1cb013534a",
      "name": "AI Agent - Summary",
      "onError": "continueRegularOutput",
      "notes": "={\n  \"error_type\": \"openai_summarization_failed\",\n  \"error_message\": \"{{ $error.message }}\",\n  \"timestamp\": \"{{ new Date().toISOString() }}\",\n  \"fallback_summary\": \"Failed to generate summary. Please review transcript manually.\"\n}"
    },
    {
      "parameters": {
        "jsCode": "\nconst body = $('Edit Fields').first().json\n// Extract input\nconst transcript = body.meeting_transcript;\nconst date = body.meeting_date;\nconst title = body.meeting_title;\nconst participants = body.participants;\n\n// Validate\nconst errors = [];\n\n// 1. Transcript validation\nif (!transcript || transcript.trim().length === 0) {\n  errors.push(\"Transcript is required and cannot be empty\");\n}\nif (transcript && transcript.trim().length < 50) {\n  errors.push(\"Transcript must be at least 50 characters long\");\n}\n\n// 2. Date validation (YYYY-MM-DD format)\nif (!date || date.trim().length === 0) {\n  errors.push(\"Date is required\");\n}\nconst dateRegex = /^\\d{4}-\\d{2}-\\d{2}$/;\nif (date && !dateRegex.test(date)) {\n  errors.push(\"Date must be in YYYY-MM-DD format (e.g., 2024-05-10)\");\n}\n\n// 3. Title validation\nif (!title || title.trim().length === 0) {\n  errors.push(\"Title is required and cannot be empty\");\n}\nif (title && title.trim().length < 3) {\n  errors.push(\"Title must be at least 3 characters\");\n}\n\n// 4. Participants validation\nif (!Array.isArray(participants)) {\n  errors.push(\"Participants must be an array\");\n}\nif (Array.isArray(participants) && participants.length === 0) {\n  errors.push(\"At least one participant is required\");\n}\n\n// Return result\nif (errors.length > 0) {\n  return {\n    valid: false,\n    errors: errors,\n    timestamp: new Date().toISOString()\n  };\n}\n\n// All valid\nreturn {\n  valid: true,\n  meeting_transcript: transcript,\n  meeting_date: date,\n  meeting_title: title,\n  participants: participants,\n  timestamp: new Date().toISOString()\n};"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        512,
