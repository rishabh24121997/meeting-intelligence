    {
      "parameters": {
        "respondWith": "json",
        "responseBody": "={\n  \"status\": \"error\",\n  \"message\": \"Invalid input\",\n  \"errors\": {{ JSON.stringify( $json.errors) }},\n  \"required_fields\": {\n    \"transcript\": \"string (min 50 characters)\",\n    \"date\": \"YYYY-MM-DD format (required)\",\n    \"title\": \"string (min 3 characters, required)\",\n    \"participants\": \"array of strings (min 1 item)\"\n  },\n  \"example\": {\n    \"title\": \"Q2 Planning Meeting\",\n    \"date\": \"2024-05-10\",\n    \"participants\": [\"Alice\", \"Bob\", \"Sarah\"],\n    \"transcript\": \"Alice: Let's discuss Q2 roadmap. We need to launch v2.0 by June 15...\"\n  },\n  \"timestamp\": \"{{ new Date().toISOString() }}\"\n} ",
        "options": {
          "responseCode": 400
        }
      },
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1.5,
      "position": [
        944,
        0
      ],
      "id": "a6080a90-5aa6-4c57-9abd-46b8a83abd40",
      "name": "Return Validation Error"
    },
    {
      "parameters": {
        "jsCode": "// Parse outputs safely\nlet summary = {};\nlet action_items = [];\nlet risks = [];\n\ntry {\n  const summaryStr = $input.first().json.summary;\n  summary = typeof summaryStr === 'string' ? JSON.parse(summaryStr) : summaryStr;\n} catch (e) {\n  summary = { error: \"Failed to parse summary\" };\n}\n\ntry {\n  const itemsStr = $input.first().json.action_items;\n  action_items = typeof itemsStr === 'string' ? JSON.parse(itemsStr) : itemsStr;\n  if (!Array.isArray(action_items)) action_items = [];\n} catch (e) {\n  action_items = [];\n}\n\ntry {\n  const risksStr = $input.first().json.risks;\n  risks = typeof risksStr === 'string' ? JSON.parse(risksStr) : risksStr;\n  if (!Array.isArray(risks)) risks = [];\n} catch (e) {\n  risks = [];\n}\n\n// Estimate token usage based on outputs (rough calculation)\n// This is an estimate since we don't have exact token counts from OpenAI\nconst summaryTokens = summary && summary.summary ? Math.ceil(summary.summary.length / 4) : 0;\nconst actionItemsTokens = action_items.length > 0 ? Math.ceil(JSON.stringify(action_items).length / 4) : 0;\nconst risksTokens = risks.length > 0 ? Math.ceil(JSON.stringify(risks).length / 4) : 0;\n\nconst totalTokensUsed = summaryTokens + actionItemsTokens + risksTokens;\n\n// Cost calculation (GPT-4o-mini: $0.00015 per input token, $0.0006 per output token)\n// Using output token cost since we're charged for responses\nconst costPerOutputToken = 0.0006;\nconst estimatedCostUsd = (totalTokensUsed * costPerOutputToken / 1000).toFixed(4);\n\n// Build final response\nconst responseData = {\n  status: \"success\",\n  message: \"Meeting processed successfully\",\n  data: {\n    summary: summary,\n    action_items: action_items,\n    risks: risks,\n    meeting_title: $input.first().json.meeting_title,\n    meeting_date: $input.first().json.meeting_date,\n    participants: $input.first().json.participants\n  },\n  metrics: {\n    action_items_count: action_items.length || 0,\n    risks_count: risks.length || 0,\n    estimated_tokens_used: totalTokensUsed,\n    estimated_cost_usd: parseFloat(estimatedCostUsd),\n    api_model: \"gpt-4o-mini\",\n    note: \"Token count is estimated based on output length. Actual tokens may vary.\"\n  },\n  timestamp: new Date().toISOString()\n};\n\nreturn responseData;"
      },
